<UserControl x:Class="PerSourceAntivirus.Gui.Views.HuntView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Threat Hunt" FontSize="20" FontWeight="Bold"
                   Foreground="#333" Margin="0,0,0,16"/>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Hunt Filters" FontSize="14" FontWeight="SemiBold"
                           Foreground="#333" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1 -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,8">
                        <TextBlock Text="Process Name" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,5" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,8,8">
                        <TextBlock Text="File Path" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,5" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="IP Address" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,5" FontSize="13"/>
                    </StackPanel>

                    <!-- Row 2 -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,0">
                        <TextBlock Text="Registry Key" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding RegistryKey, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,5" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,8,0">
                        <TextBlock Text="SHA-256 Hash" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                        <TextBox Text="{Binding Hash, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,5" FontSize="13" FontFamily="Consolas"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="1" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Search" Command="{Binding SearchCommand}"
                                    Padding="20,7" Background="{StaticResource AccentBrush}"
                                    Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                            <Button Content="Clear" Command="{Binding ClearCommand}"
                                    Padding="16,7" Background="#EEE" Foreground="#333"
                                    BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#666"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="  Buscando..." FontSize="12" Foreground="{StaticResource AccentBrush}"
                               FontStyle="Italic" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Results tabs -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <TabControl BorderThickness="0" Background="Transparent">

                <!-- Processes tab -->
                <TabItem Header="Processos">
                    <DataGrid ItemsSource="{Binding Processes}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#FAFAFA" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID"          Binding="{Binding ProcessId}"     Width="60"/>
                            <DataGridTextColumn Header="Nome"         Binding="{Binding FileName}"      Width="140"/>
                            <DataGridTextColumn Header="Linha de Cmd" Binding="{Binding CommandLine}"   Width="*"/>
                            <DataGridTextColumn Header="Usuário"      Binding="{Binding UserName}"      Width="100"/>
                            <DataGridTextColumn Header="Integridade"  Binding="{Binding IntegrityLevel}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Suspeito" Binding="{Binding IsSuspicious}"  Width="80"/>
                            <DataGridTextColumn Header="Hora"
                                                Binding="{Binding CreatedAtUtc, StringFormat={}{0:HH:mm:ss}}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Files tab -->
                <TabItem Header="Arquivos">
                    <DataGrid ItemsSource="{Binding Files}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#FAFAFA" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID"       Binding="{Binding ProcessId}"   Width="60"/>
                            <DataGridTextColumn Header="Processo"  Binding="{Binding ProcessName}" Width="120"/>
                            <DataGridTextColumn Header="Operação"  Binding="{Binding Operation}"   Width="90"/>
                            <DataGridTextColumn Header="Arquivo"   Binding="{Binding FileName}"    Width="160"/>
                            <DataGridTextColumn Header="Caminho"   Binding="{Binding FilePath}"    Width="*"/>
                            <DataGridCheckBoxColumn Header="Suspeito" Binding="{Binding IsSuspicious}" Width="80"/>
                            <DataGridTextColumn Header="Hora"
                                                Binding="{Binding OccurredAtUtc, StringFormat={}{0:HH:mm:ss}}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Registry tab -->
                <TabItem Header="Registro">
                    <DataGrid ItemsSource="{Binding Registry}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#FAFAFA" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PID"      Binding="{Binding ProcessId}"   Width="60"/>
                            <DataGridTextColumn Header="Processo" Binding="{Binding ProcessName}" Width="120"/>
                            <DataGridTextColumn Header="Operação" Binding="{Binding Operation}"   Width="80"/>
                            <DataGridTextColumn Header="Chave"    Binding="{Binding KeyPath}"     Width="*"/>
                            <DataGridTextColumn Header="Valor"    Binding="{Binding ValueName}"   Width="130"/>
                            <DataGridCheckBoxColumn Header="Suspeito" Binding="{Binding IsSuspicious}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- Network tab -->
                <TabItem Header="Rede">
                    <DataGrid ItemsSource="{Binding Network}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#FAFAFA" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Proto"    Binding="{Binding Protocol}"          Width="60"/>
                            <DataGridTextColumn Header="Origem"   Binding="{Binding SourceAddress}"     Width="130"/>
                            <DataGridTextColumn Header="P.Orig"   Binding="{Binding SourcePort}"        Width="70"/>
                            <DataGridTextColumn Header="Destino"  Binding="{Binding DestinationAddress}" Width="130"/>
                            <DataGridTextColumn Header="P.Dest"   Binding="{Binding DestinationPort}"   Width="70"/>
                            <DataGridCheckBoxColumn Header="Bloq." Binding="{Binding IsBlocklisted}"    Width="60"/>
                            <DataGridTextColumn Header="Hora"
                                                Binding="{Binding CapturedAtUtc, StringFormat={}{0:HH:mm:ss}}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
