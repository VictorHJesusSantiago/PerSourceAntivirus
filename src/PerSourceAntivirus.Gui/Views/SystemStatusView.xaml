<UserControl x:Class="PerSourceAntivirus.Gui.Views.SystemStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="24">
        <TextBlock Text="System Status" FontSize="20" FontWeight="Bold"
                   Foreground="#333" Margin="0,0,0,16"/>

        <UniformGrid Columns="3">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="CPU" FontSize="12" Foreground="#888" Margin="0,0,0,8"/>
                    <Border Width="16" Height="16" CornerRadius="8" Margin="0,0,0,8"
                            Background="{Binding CpuStatusColor}"/>
                    <TextBlock Text="{Binding CpuStatusText}" FontSize="15"
                               FontWeight="Bold" Foreground="#333"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Gaming Mode" FontSize="12" Foreground="#888" Margin="0,0,0,8"/>
                    <Border Width="16" Height="16" CornerRadius="8" Margin="0,0,0,8"
                            Background="{Binding GamingStatusColor}"/>
                    <TextBlock Text="{Binding GamingModeText}" FontSize="15"
                               FontWeight="Bold" Foreground="#333"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Power" FontSize="12" Foreground="#888" Margin="0,0,0,8"/>
                    <Border Width="16" Height="16" CornerRadius="8" Margin="0,0,0,8"
                            Background="{Binding BatteryStatusColor}"/>
                    <TextBlock Text="{Binding BatteryStatusText}" FontSize="15"
                               FontWeight="Bold" Foreground="#333"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </StackPanel>
</UserControl>
