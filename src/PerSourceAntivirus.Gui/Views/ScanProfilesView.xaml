<UserControl x:Class="PerSourceAntivirus.Gui.Views.ScanProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Scan Profiles" FontSize="20" FontWeight="Bold"
                   Foreground="#333" Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <Button DockPanel.Dock="Bottom" Content="+ New Profile"
                            Command="{Binding NewProfileCommand}"
                            Margin="0,8,0,0" Padding="8,6"
                            Background="{StaticResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                    <ListBox ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             Background="Transparent" BorderThickness="0"
                             DisplayMemberPath="Name"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Edit Profile" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#333" Margin="0,0,0,16"/>

                        <TextBlock Text="Name" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" BorderBrush="#CCCCCC" BorderThickness="1"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Profile Type" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding EditType}" Padding="8,6"
                                  HorizontalAlignment="Left" Width="160" Margin="0,0,0,12">
                            <ComboBoxItem Content="Quick"/>
                            <ComboBoxItem Content="Full"/>
                            <ComboBoxItem Content="Custom"/>
                            <ComboBoxItem Content="Scheduled"/>
                        </ComboBox>

                        <TextBlock Text="Include Paths (semicolon-separated)" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditIncludePaths, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" BorderBrush="#CCCCCC" BorderThickness="1"
                                 AcceptsReturn="False" Margin="0,0,0,12"/>

                        <TextBlock Text="Exclude Paths (semicolon-separated)" FontSize="12"
                                   Foreground="#555" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding EditExcludePaths, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" BorderBrush="#CCCCCC" BorderThickness="1"
                                 AcceptsReturn="False" Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save Profile" Command="{Binding SaveProfileCommand}"
                                    Padding="14,8"
                                    Background="{StaticResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                            <Button Content="Delete Profile" Command="{Binding DeleteProfileCommand}"
                                    Padding="14,8"
                                    Background="{StaticResource DangerBrush}" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
