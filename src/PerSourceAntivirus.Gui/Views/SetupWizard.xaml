<Window x:Class="PerSourceAntivirus.Gui.Views.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PerSource Antivirus Setup" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E2E" Padding="24,20">
            <StackPanel>
                <TextBlock Text="🛡 PerSource Antivirus Setup" FontSize="18" FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock FontSize="12" Foreground="#AAAACC" Margin="0,4,0,0">
                    <Run Text="Step "/>
                    <Run Text="{Binding ElementName=wizard, Path=CurrentStep}"/>
                    <Run Text=" of 5"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#F5F5F5" Padding="32">
            <ContentControl x:Name="StepContent"/>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="16,12">
            <DockPanel>
                <Button x:Name="BtnFinish" Content="Finish" DockPanel.Dock="Right"
                        Padding="20,8" Margin="8,0,0,0"
                        Background="#4AFF8A" Foreground="#333"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnFinish_Click" Visibility="Collapsed"/>
                <Button x:Name="BtnNext" Content="Next ▶" DockPanel.Dock="Right"
                        Padding="20,8"
                        Background="#4A9EFF" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnNext_Click"/>
                <Button x:Name="BtnPrev" Content="◀ Previous" DockPanel.Dock="Right"
                        Padding="20,8" Margin="0,0,8,0"
                        Background="#888888" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnPrev_Click" IsEnabled="False"/>
                <ProgressBar Value="{Binding ElementName=wizard, Path=CurrentStep}"
                             Maximum="5" Minimum="1" Height="8"
                             Background="#E0E0E0" Foreground="#4A9EFF"
                             VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
