<UserControl x:Class="PerSourceAntivirus.Gui.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Status banner -->
            <Border CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Background>
                    <SolidColorBrush Color="{Binding ProtectionColor}"/>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="{Binding ProtectionStatus}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="PerSource Antivirus — real-time protection active" FontSize="12" Foreground="#DDFFFFFF" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Stats row -->
            <UniformGrid Columns="3">
                <!-- Total scanned -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalScanned}" FontSize="36" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock Text="Files Scanned" Foreground="#666" FontSize="13"/>
                    </StackPanel>
                </Border>
                <!-- Threats -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding ThreatCount}" FontSize="36" FontWeight="Bold" Foreground="#FF4A4A"/>
                        <TextBlock Text="Threats Detected" Foreground="#666" FontSize="13"/>
                    </StackPanel>
                </Border>
                <!-- Suspicious -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding SuspiciousCount}" FontSize="36" FontWeight="Bold" Foreground="#FFB24A"/>
                        <TextBlock Text="Suspicious Files" Foreground="#666" FontSize="13"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Last scan -->
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Last Scan" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                    <TextBlock FontSize="13" Foreground="#555">
                        <TextBlock.Text>
                            <Binding Path="LastScanTime" StringFormat="{}{0:yyyy-MM-dd HH:mm:ss}" FallbackValue="No scans yet"/>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="{Binding Status}" Foreground="#888" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
